# New integrations should use the interactive browser flow. These legacy
# variables remain optional only for backward-compatible export commands.
COROS_API_URL=
COROS_EMAIL=
COROS_PASSWORD=

COROS_DEFAULT_REGION=eu
COROS_SESSION_ENCRYPTION_KEY=
COROS_SESSION_STORAGE_PATH=.local/coros/sessions.enc
COROS_PROTOCOL_FIXTURE_PATH=fixtures/protocol
COROS_PROTOCOL_RECORDER_ENABLED=false
COROS_WRITE_API_ENABLED=false
COROS_REMOTE_BROWSER_AUTH_ENABLED=false

# Required only by the localhost service-to-service REST API.
COROS_SERVICE_TOKEN=
