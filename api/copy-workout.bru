meta {
  name: Copy Workout
  type: http
  seq: 19
}

post {
  url: {{LOCAL_API_URL}}/api/v1/coros/accounts/{{ACCOUNT_ID}}/workouts/{{WORKOUT_ID}}/copy
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{SERVICE_TOKEN}}
}

docs {
  Returns a versioned clipboard from the exact locally stored managed snapshot.
  It does not create another COROS workout.
}
