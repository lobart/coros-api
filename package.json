{
  "name": "coros-api",
  "version": "2.0.1",
  "description": "Coros API",
  "scripts": {
    "build": "nest build",
    "format:check": "biome format src",
    "format:fix": "biome format --write src",
    "start": "nest start",
    "start:http": "node dist/http-main",
    "start:prod": "node dist/main",
    "lint:fix": "biome check --write --no-errors-on-unmatched .",
    "lint:check": "biome check --no-errors-on-unmatched .",
    "lint:ci": "biome ci --no-errors-on-unmatched",
    "test": "vitest --run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lobart/coros-api.git"
  },
